        "description": "Environment (dev, test, prod)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources"
      }
    },
    "enablePrivateEndpoints": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable private endpoints"
      }
    },
    "fabricSku": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Fabric capacity SKU to provision (e.g. F2, F4, F8, F16, F32, F64, F128, F256, F512, F1024, F2048, Trial).\nLeave empty to skip capacity provisioning and use an existing capacity via the deploy workflow input.\n"
      }
    },
    "fabricCapacityName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Override the auto-generated Fabric capacity name (optional). Must be lowercase alphanumeric + hyphens, 3-63 chars, globally unique per region."
      }
    },
    "fabricCapacityAdmins": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "UPNs / email addresses of Fabric capacity admins (required when fabricSku is set). E.g. [\"admin@contoso.com\"]"
      }
    }
  },
  "variables": {
    "vnetName": "[format('vnet-{0}-{1}', parameters('baseName'), parameters('env'))]",
    "logAnalyticsName": "[format('log-{0}-{1}', parameters('baseName'), parameters('env'))]",
    "resolvedCapacityName": "[if(empty(parameters('fabricCapacityName')), format('cap{0}{1}', replace(toLower(parameters('baseName')), '-', ''), replace(toLower(parameters('env')), '-', '')), parameters('fabricCapacityName'))]"
  },
  "resources": [
    {
