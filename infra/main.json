              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for the Fabric capacity"
              }
            },
            "fabricSku": {
              "type": "string",
              "allowedValues": [
                "F2",
                "F4",
                "F8",
                "F16",
                "F32",
                "F64",
                "F128",
                "F256",
                "F512",
                "F1024",
                "F2048",
                "Trial"
              ],
              "metadata": {
                "description": "Fabric capacity SKU.\nF2–F2048  : paid Fabric compute SKUs (F2, F4, F8, F16, F32, F64, F128, F256, F512, F1024, F2048)\nTrial     : free 60-day trial (maps to F1 / Trial tier, one per tenant)\n"
              }
            },
            "adminMembers": {
              "type": "array",
              "metadata": {
                "description": "UPNs / email addresses of Fabric capacity administrators (at least one required)"
              }
            }
          },
          "variables": {
            "skuName": "[if(equals(parameters('fabricSku'), 'Trial'), 'F1', parameters('fabricSku'))]",
            "skuTier": "[if(equals(parameters('fabricSku'), 'Trial'), 'Trial', 'Fabric')]"
          },
          "resources": [
            {
              "type": "Microsoft.Fabric/capacities",
              "apiVersion": "2023-11-01",
              "name": "[parameters('capacityName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "[variables('skuName')]",
                "tier": "[variables('skuTier')]"
              },
              "properties": {
                "administration": {
                  "members": "[parameters('adminMembers')]"
                }
              }
            }
          ],
          "outputs": {
            "capacityName": {
              "type": "string",
              "value": "[parameters('capacityName')]"
            },
            "capacityAzureResourceId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Fabric/capacities', parameters('capacityName'))]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "acrName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'acr-deployment'), '2025-04-01').outputs.acrName.value]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'keyvault-deployment'), '2025-04-01').outputs.keyVaultName.value]"
    },
    "backendAppName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appservices-deployment'), '2025-04-01').outputs.backendAppName.value]"
    },
    "frontendAppName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appservices-deployment'), '2025-04-01').outputs.frontendAppName.value]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'monitoring-deployment'), '2025-04-01').outputs.logAnalyticsId.value]"
    },
    "vnetId": {
      "type": "string",
      "value": "[coalesce(tryGet(if(parameters('enablePrivateEndpoints'), reference(resourceId('Microsoft.Resources/deployments', 'networking-deployment'), '2025-04-01'), null()), 'outputs', 'vnetId', 'value'), '')]"
    },
    "fabricCapacityName": {
      "type": "string",
      "value": "[coalesce(tryGet(if(not(empty(parameters('fabricSku'))), reference(resourceId('Microsoft.Resources/deployments', 'fabric-capacity-deployment'), '2025-04-01'), null()), 'outputs', 'capacityName', 'value'), '')]"
    }
  }
}